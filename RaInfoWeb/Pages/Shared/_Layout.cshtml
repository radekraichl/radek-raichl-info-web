<!DOCTYPE html>
<html lang="cs">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Radek Raichl - @ViewData["Title"]</title>

    <!-- Favicon -->
    <!-- SVG favicon for modern browsers -->
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg">

    <!-- PNG favicon as a fallback for older browsers -->
    <link rel="icon" type="image/png" href="/favicon/favicon-32x32.png" sizes="32x32">
    <link rel="icon" type="image/png" href="/favicon/favicon-512x512.png" sizes="512x512">

    <!-- Material Icons -->
    <link rel="stylesheet" href="https://cdn.materialdesignicons.com/7.2.96/css/materialdesignicons.min.css">

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RaInfoWeb.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">
    <!-- Header -->
    <header>
        <nav class="navbar mb-4">
            <div class="container">
                <span class="navbar-brand">rainfo.cz</span>
            </div>
        </nav>
    </header>

    <div class="container mb-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="py-3">
        <div class="container">
            Tento web nepoužívá cookies ani nesbírá osobní údaje.<br>
            Vytvořil <a href="#">Radek Raichl</a> &bull; 2024<br>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
